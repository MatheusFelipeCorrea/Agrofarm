@startuml agrofarm-casos-uso
' Versão: 2.0
' Data: 21/06/2026
' Autor: Matheus Felipe Correa
' Diagrama de Casos de Uso — Agrofarm

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title Casos de Uso — Agrofarm\n<v2.0 — 21/06/2026 — Matheus Felipe Correa>

actor "Administrador\n(ADMIN)" as ADMIN
actor "Funcionário\n(FUNCIONARIO)" as FUNC
actor "Sistema\n(Cron Jobs)" as SISTEMA

rectangle "Agrofarm" {

  package "Autenticação e Conta" {
    usecase "Realizar login" as UC_LOGIN
    usecase "Recuperar senha" as UC_RECUPERAR
    usecase "Redefinir senha" as UC_REDEFINIR
    usecase "Trocar senha inicial" as UC_TROCAR_INICIAL
    usecase "Alterar senha" as UC_ALTERAR
  }

  package "Gestão Operacional (ADMIN)" {
    usecase "Visualizar dashboard" as UC_DASHBOARD
    usecase "Gerenciar fazendas e mapa" as UC_FAZENDAS
    usecase "Gerenciar culturas e talhões" as UC_CULTURAS
    usecase "Registrar colheitas" as UC_COLHEITAS
    usecase "Gerenciar estoque e arrendamento" as UC_ESTOQUE
    usecase "Registrar lucros" as UC_LUCROS
    usecase "Registrar gastos" as UC_GASTOS
    usecase "Gerenciar insumos" as UC_INSUMOS_ADMIN
    usecase "Gerenciar lembretes" as UC_LEMBRETES
    usecase "Gerenciar usuários e vínculos" as UC_USUARIOS
  }

  package "Financeiro e Mercado (ADMIN)" {
    usecase "Consultar cotações" as UC_COTACOES
    usecase "Simular exportação" as UC_SIMULACAO
    usecase "Consultar histórico de simulações" as UC_HIST_SIM
  }

  package "Inteligência (ADMIN)" {
    usecase "Conversar com Chat IA" as UC_CHATBOT
    usecase "Gerar insights inteligentes" as UC_INSIGHTS
    usecase "Consultar notícias agrícolas" as UC_NOTICIAS
    usecase "Consultar previsão do clima" as UC_CLIMA
  }

  package "Operação do Funcionário" {
    usecase "Registrar insumos da fazenda" as UC_INSUMOS_FUNC
  }

  package "Notificações" {
    usecase "Receber notificações in-app" as UC_NOTIF
  }

  package "Processos Automáticos" {
    usecase "Enviar lembretes via WhatsApp" as UC_JOB_LEMBRETES
    usecase "Atualizar cotações periodicamente" as UC_JOB_COT_UPDATE
    usecase "Limpar cotações antigas" as UC_JOB_COT_CLEANUP
    usecase "Arquivar talhões colhidos" as UC_JOB_MAPA
  }
}

' Autenticação
ADMIN --> UC_LOGIN
FUNC --> UC_LOGIN
ADMIN --> UC_RECUPERAR
FUNC --> UC_RECUPERAR
ADMIN --> UC_REDEFINIR
FUNC --> UC_REDEFINIR
ADMIN --> UC_TROCAR_INICIAL
FUNC --> UC_TROCAR_INICIAL
ADMIN --> UC_ALTERAR
FUNC --> UC_ALTERAR

' Gestão operacional ADMIN
ADMIN --> UC_DASHBOARD
ADMIN --> UC_FAZENDAS
ADMIN --> UC_CULTURAS
ADMIN --> UC_COLHEITAS
ADMIN --> UC_ESTOQUE
ADMIN --> UC_LUCROS
ADMIN --> UC_GASTOS
ADMIN --> UC_INSUMOS_ADMIN
ADMIN --> UC_LEMBRETES
ADMIN --> UC_USUARIOS

' Financeiro e mercado
ADMIN --> UC_COTACOES
ADMIN --> UC_SIMULACAO
ADMIN --> UC_HIST_SIM
UC_SIMULACAO ..> UC_COTACOES : <<include>>

' Inteligência
ADMIN --> UC_CHATBOT
ADMIN --> UC_INSIGHTS
ADMIN --> UC_NOTICIAS
ADMIN --> UC_CLIMA
UC_NOTICIAS ..> UC_CLIMA : <<extend>>

' Funcionário
FUNC --> UC_INSUMOS_FUNC

' Notificações
ADMIN --> UC_NOTIF
FUNC --> UC_NOTIF

' Jobs automáticos
SISTEMA --> UC_JOB_LEMBRETES
SISTEMA --> UC_JOB_COT_UPDATE
SISTEMA --> UC_JOB_COT_CLEANUP
SISTEMA --> UC_JOB_MAPA
UC_JOB_LEMBRETES ..> UC_NOTIF : <<include>>
UC_JOB_MAPA ..> UC_FAZENDAS : <<include>>

@enduml
