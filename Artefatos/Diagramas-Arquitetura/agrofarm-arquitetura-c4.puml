@startuml agrofarm-arquitetura-c4
' Versão: 2.0
' Data: 21/06/2026
' Autor: Matheus Felipe Correa
' Diagrama C4 — Nível 2 (Containers) do sistema Agrofarm

!include <C4/C4_Container>

title Diagrama de Arquitetura — Agrofarm (C4 Nível 2)\n<v2.0 — 21/06/2026 — Matheus Felipe Correa>

Person(usuario, "Usuário", "Administrador ou Funcionário\nacessa o sistema via navegador")

System_Boundary(agrofarm, "Agrofarm") {
    Container(web, "Frontend SPA", "React 18, Vite, Tailwind", "Interface web: dashboard, fazendas, mapa,\nestoque, simulação, chatbot, notícias e clima")
    Container(api, "API Backend", "Node.js, Express", "REST /api: auth, CRUD, IA, notícias,\ncotações, simulação, estoque e crons")
    ContainerDb(db, "Banco de Dados", "PostgreSQL (Neon) + PostGIS", "Persistência via Prisma ORM:\nusuários, fazendas, colheitas, polígonos,\nchat, simulações, notificações")
    Container(jobs, "Jobs em Background", "node-cron + rotas /crons", "Lembretes WhatsApp, atualização/limpeza\nde cotações, arquivamento de talhões")
}

System_Ext(gemini, "Google Gemini", "Chat IA, insights inteligentes\ne categorização de notícias")
System_Ext(evolution, "Evolution API", "Envio de lembretes via WhatsApp")
System_Ext(cotacoes_ext, "APIs de Cotação", "AwesomeAPI, Yahoo Finance, Stooq\n(soja, milho, café, trigo, algodão)")
System_Ext(ibpt, "IBPT / Valraw", "Estimativa de taxas para\nsimulação de exportação")
System_Ext(resend, "Resend", "E-mail transacional\n(recuperação de senha)")
System_Ext(rss, "Feeds RSS", "Fontes de notícias do agronegócio")
System_Ext(openmeteo, "Open-Meteo", "Previsão do tempo\n(consumido pelo frontend)")

Rel(usuario, web, "Utiliza", "HTTPS")
Rel(web, api, "Chama API", "JSON/REST, JWT")
Rel(web, openmeteo, "Consulta clima", "HTTPS")
Rel(api, db, "Lê/Escreve", "Prisma, SQL")
Rel(jobs, db, "Processa dados", "Prisma")
Rel(jobs, evolution, "Envia mensagens", "HTTPS")
Rel(api, gemini, "Gera respostas e insights", "HTTPS")
Rel(api, evolution, "Envia lembretes", "HTTPS")
Rel(api, cotacoes_ext, "Busca cotações", "HTTPS")
Rel(api, ibpt, "Calcula taxas", "HTTPS")
Rel(api, resend, "Envia e-mails", "HTTPS")
Rel(api, rss, "Agrega notícias", "HTTPS/RSS")
Rel(api, jobs, "Dispara crons externos", "/api/crons/*")

SHOW_LEGEND()

@enduml
