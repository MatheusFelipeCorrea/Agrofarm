@startuml agrofarm-classes-dominio
' Versão: 2.0
' Data: 21/06/2026
' Autor: Matheus Felipe Correa
' Diagrama de Classes de Domínio — models Prisma (Agrofarm)

skinparam classAttributeIconSize 0
hide empty members

title Diagrama de Classes de Domínio — Agrofarm\n<v2.0 — 21/06/2026 — Matheus Felipe Correa>

class usuarios {
  +id: UUID
  +nome: String
  +email: String
  +senha: String
  +role: role
  +telefone: String?
  +token_reset: String?
  +token_reset_expira: DateTime?
  +must_change_password: Boolean
  +token_version: Int
  +criado_em: DateTime
}

class fazendas {
  +id: UUID
  +nome: String
  +tipo: tipo_fazenda
  +localizacao: String?
  +latitude: Decimal?
  +longitude: Decimal?
  +ativa: Boolean
  +arrendamento_cultura_id: UUID?
  +arrendamento_quantidade_sacas: Decimal?
  +arrendamento_periodicidade: periodicidade_arrendamento?
  +arrendamento_data_inicio: Date?
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class culturas {
  +id: UUID
  +nome: String
  +cor: String
  +hectares: Decimal
  +criado_em: DateTime
}

class fazenda_culturas {
  +id: UUID
  +fazenda_id: UUID
  +cultura_id: UUID
  +hectares: Decimal
  +status: status_cultura
  +criado_em: DateTime
  +deletado_em: DateTime?
  +deletado_por: UUID?
}

class usuarios_fazendas {
  +id: UUID
  +usuario_id: UUID
  +fazenda_id: UUID
  +criado_em: DateTime
}

class colheitas {
  +id: UUID
  +fazenda_id: UUID
  +cultura_id: UUID
  +area: Decimal
  +sacas_produzidas: Decimal
  +ano: Int
  +data_colheita: Date
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class gastos {
  +id: UUID
  +colheita_id: UUID
  +tipo: String
  +tipo_personalizado: String?
  +valor: Decimal
  +data_vencimento: Date?
  +status: status_gasto
  +descricao: String?
  +data: Date
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class lucros {
  +id: UUID
  +colheita_id: UUID?
  +fazenda_id: UUID?
  +origem: origem_lucro
  +status_recebimento: status_recebimento_arrendamento?
  +quantidade_sacas: Decimal
  +valor_unitario: Decimal
  +comprador: String
  +data: Date
  +criado_em: DateTime
}

class entregas_arrendamento {
  +id: UUID
  +fazenda_id: UUID
  +cultura_id: UUID
  +quantidade_sacas: Decimal
  +data: Date
  +status: status_entrega_arrendamento
  +colheita_id: UUID?
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class insumos_atividades {
  +id: UUID
  +funcionario_id: UUID
  +fazenda_id: UUID
  +item: String
  +categoria: String
  +quantidade: Decimal
  +unidade: String
  +valor_unitario: Decimal
  +fornecedor: String?
  +observacoes: String?
  +data: Date
  +criado_em: DateTime
}

class lembretes {
  +id: UUID
  +usuario_id: UUID
  +fazenda_id: UUID?
  +colheita_id: UUID?
  +poligono_id: UUID?
  +titulo: String
  +descricao: String?
  +data_lembrete: DateTime
  +telefone_whatsapp: String?
  +status: status_lembrete
  +recorrencia: recorrencia_lembrete
  +recorrencia_custom: String?
  +criado_em: DateTime
  +enviado_em: DateTime?
  +erro_envio: String?
}

class notificacoes {
  +id: UUID
  +usuario_id: UUID
  +tipo: tipo_notificacao
  +titulo: String
  +descricao: String?
  +rota: String?
  +referencia_id: UUID?
  +lida_em: DateTime?
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class cotacoes {
  +id: UUID
  +valor: Decimal
  +fonte: String
  +atualizado_em: DateTime
}

class simulacoes {
  +id: UUID
  +usuario_id: UUID
  +fazenda_id: UUID?
  +cultura_id: UUID
  +quantidade_sacas: Decimal
  +valor_saca: Decimal
  +moeda: String
  +taxa_cambio_manual: Decimal?
  +valor_bruto: Decimal
  +valor_liquido: Decimal
  +composicao_taxas: Json
  +abatimento_divida: Decimal
  +novo_saldo_divida: Decimal
  +criado_em: DateTime
}

class poligonos_fazenda {
  +id: UUID
  +fazenda_id: UUID
  +cultura_id: UUID?
  +nome: String
  +geometria: geometry(Polygon)
  +area_hectares: Decimal
  +data_plantio: Date?
  +data_colheita: Date?
  +criado_por: UUID?
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class poligonos_fazenda_historico {
  +id: UUID
  +fazenda_id: UUID
  +poligono_id_origem: UUID?
  +nome: String
  +cultura_id: UUID?
  +colheita_id: UUID?
  +data_plantio: Date?
  +data_colheita: Date?
  +area_hectares: Decimal
  +geometria: geometry(Polygon)
  +status: status_historico_mapa
  +arquivado_em: DateTime
  +restaurado_em: DateTime?
}

class chat_sessoes {
  +id: UUID
  +usuario_id: UUID
  +titulo: String?
  +criado_em: DateTime
  +atualizado_em: DateTime
}

class chat_mensagens {
  +id: UUID
  +sessao_id: UUID
  +papel: String
  +conteudo: String
  +metadados: Json?
  +criado_em: DateTime
}

class insight_snapshots {
  +id: UUID
  +tipo: String
  +fazenda_id: UUID?
  +escopo: String
  +conteudo: Json
  +gerado_por: UUID
  +gerado_em: DateTime
}

enum role {
  ADMIN
  FUNCIONARIO
}

enum tipo_fazenda {
  PROPRIA
  ARRENDADA_DE_TERCEIROS
  ARRENDADA_PARA_TERCEIROS
}

enum status_gasto {
  PAGO
  PENDENTE
}

enum status_lembrete {
  PENDENTE
  ENVIADO
  CANCELADO
}

enum status_cultura {
  SECAGEM
  COLHEITA
  PLANTIO
  ADUBACAO
  PULVERIZACAO
}

enum tipo_notificacao {
  LEMBRETE
  INSUMO_NOVO
  ARRENDAMENTO_RECEBER
  GASTO_ATRASADO
}

enum origem_lucro {
  VENDA_COLHEITA
  ARRENDAMENTO
}

' Relacionamentos principais
usuarios "1" -- "0..*" usuarios_fazendas
fazendas "1" -- "0..*" usuarios_fazendas

usuarios "1" -- "0..*" insumos_atividades : registra
fazendas "1" -- "0..*" insumos_atividades

fazendas "1" -- "0..*" fazenda_culturas
culturas "1" -- "0..*" fazenda_culturas

fazendas "1" -- "0..*" colheitas
culturas "1" -- "0..*" colheitas
colheitas "1" -- "0..*" gastos
colheitas "1" -- "0..*" lucros

fazendas "0..1" -- "0..*" lucros : arrendamento
fazendas "0..1" -- "0..1" culturas : arrendamento_cultura

fazendas "1" -- "0..*" entregas_arrendamento
culturas "1" -- "0..*" entregas_arrendamento
colheitas "0..1" -- "0..*" entregas_arrendamento

usuarios "1" -- "0..*" lembretes
fazendas "0..1" -- "0..*" lembretes
colheitas "0..1" -- "0..*" lembretes
poligonos_fazenda "0..1" -- "0..*" lembretes

usuarios "1" -- "0..*" notificacoes

usuarios "1" -- "0..*" chat_sessoes
chat_sessoes "1" -- "0..*" chat_mensagens

usuarios "1" -- "0..*" simulacoes
fazendas "0..1" -- "0..*" simulacoes
culturas "1" -- "0..*" simulacoes

fazendas "1" -- "0..*" poligonos_fazenda
culturas "0..1" -- "0..*" poligonos_fazenda
usuarios "0..1" -- "0..*" poligonos_fazenda : criado_por

fazendas "1" -- "0..*" poligonos_fazenda_historico
culturas "0..1" -- "0..*" poligonos_fazenda_historico
colheitas "0..1" -- "0..*" poligonos_fazenda_historico

usuarios "1" -- "0..*" insight_snapshots : gerado_por
fazendas "0..1" -- "0..*" insight_snapshots

usuarios .. role
fazendas .. tipo_fazenda
gastos .. status_gasto
lembretes .. status_lembrete
fazenda_culturas .. status_cultura
notificacoes .. tipo_notificacao
lucros .. origem_lucro

@enduml
