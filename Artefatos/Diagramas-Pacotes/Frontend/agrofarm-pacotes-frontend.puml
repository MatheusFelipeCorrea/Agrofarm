@startuml agrofarm-pacotes-frontend
' Versão: 2.0
' Data: 21/06/2026
' Autor: Matheus Felipe Correa
' Diagrama de Pacotes — Frontend (web/src)

skinparam packageStyle rectangle

title Pacotes Frontend — Agrofarm (web/src)\n<v2.0 — 21/06/2026 — Matheus Felipe Correa>

package "web" {
  [App.jsx]
  [main.jsx]

  package "pages" {
    package "Auth" {
      [Login]
      [RecuperarSenha]
      [RedefinirSenha]
      [TrocarSenhaInicial]
      [AlterarSenha]
    }
    package "Dashboard" {
      [Dashboard]
      [DashboardCards]
      [DashboardEstoqueSection]
      [DashboardProducaoSection]
      [DashboardExtratoSection]
    }
    package "Fazendas" {
      [Fazendas]
      [FazendaDetalhe]
      [MapView / PolygonEditor]
    }
    package "Colheitas" { [Colheitas] }
    package "Estoque" { [Estoque] }
    package "Lucros" { [Lucros] }
    package "Gastos" { [Gastos] }
    package "Insumos" { [Insumos] }
    package "Lembretes" { [Lembretes] }
    package "Simulacao" { [Simulacao] }
    package "Chatbot" { [Chatbot] }
    package "Insights" { [Insights] }
    package "Noticias" {
      [Noticias]
      [PrevisaoClimaModal]
    }
    package "Usuarios" { [GerenciarUsuarios] }
  }

  package "components" {
    package "ui" {
      [Button, Input, Badge]
      [DatePickerFilter]
      [SoftBadge, FieldTooltip]
      [pickers]
    }
    package "shared" {
      [Header, Sidebar, Footer]
      [FloatingChatFab]
    }
    package "auth" { [ChangeInitialPasswordModal] }
    package "fazenda" { [FazendaVisaoGeral, FazendaCulturaVinculoModal] }
    package "gastos" { [GastoForm, GastoTable] }
    package "lucros" { [LucroTable] }
    package "lembretes" { [LembreteCalendar, LembreteFormModal] }
    package "estoque" { [EstoqueArrendamentoPanel] }
    package "usuarios" { [UsuariosTable, UserFormModal] }
    package "insights" { [InsightCard] }
    package "cultura" { [cultura components] }
    package "dialogs" { [modais compartilhados] }
  }

  package "layouts" {
    [MainLayout]
  }

  package "routes" {
    [ProtectedRoute]
    [AdminRoute]
    [routeAccess]
  }

  package "queries" {
    [useSessionQuery]
    [useDashboardQueries]
    [useFazendaQueries]
    [useColheitaQueries]
    [useEstoqueQueries]
    [useGastoQueries]
    [useLucroQueries]
    [useInsumoQueries]
    [useLembreteQueries]
    [useNotificacaoQueries]
    [useCotacaoQueries]
    [useSimulacaoQueries]
    [useChatbotQueries]
    [useIAQueries]
    [useNoticiaQueries]
    [useWeatherForecastQuery]
    [useUsuarioQueries]
    [usePoligonoQueries]
  }

  package "services" {
    [auth.service]
    [fazenda.service]
    [cultura.service]
    [colheita.service]
    [estoque.service]
    [gasto.service]
    [lucro.service]
    [insumo.service]
    [lembrete.service]
    [notificacao.service]
    [cotacao.service]
    [simulacao.service]
    [chatbot.service]
    [ia.service]
    [noticia.service]
    [usuario.service]
    [poligono.service]
    [dashboard.service]
  }

  package "store" {
    [authStore]
    package "slices" { [fazendaSlice] }
  }

  package "hooks" {
    [hooks compartilhados]
  }

  package "lib" {
    [queryClient]
    [notify]
    [ensureMenuComplete]
    package "weather" {
      [openMeteo]
      [weatherCodes]
    }
  }

  package "utils" {
    [validators]
    [apiError]
    [formatters]
    [poligonoTalhao]
    [fazendaOperacao]
    [insightTextHighlight]
  }

  package "constants" {
    [createButton]
  }

  package "styles" {
    [CSS globais e por módulo]
  }

  package "assets" {
    [imagens e ícones]
  }
}

' Dependências entre camadas
App --> routes
App --> pages
pages --> components
pages --> layouts
pages --> queries
queries --> services
queries --> lib
services --> "API Backend\n(/api REST)"
pages --> store
routes --> store
components --> utils
components --> lib

@enduml
