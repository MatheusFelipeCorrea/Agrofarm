# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados
DATABASE_URL=
DIRECT_URL=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# URL do front para links em e-mail (redefinição de senha). Se vazio, usa a primeira origem de CORS_ORIGIN.
# WEB_APP_URL=http://localhost:5173

# API WPP
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=agrofarm-evolution-dev-key-2026
EVOLUTION_INSTANCE=agrofarm

# API GEMINI (chat IA — chave em https://aistudio.google.com/apikey , sem aspas)
# Formatos válidos: AIza… (legado) ou AQ.… (contas mais novas)
GEMINI_API_KEY_CHATBOT=
# Opcional: mesma chave se preferir um único env (fallback do chatbot)
# GEMINI_API_KEY=
GEMINI_API_KEY_INSIGHTS=

# Reset semanal de histórico de cotações (dólar/euro)
# Padrão: domingo às 03:00 (timezone abaixo).
# No reset semanal, o histórico é apagado e o sistema já tenta buscar USD/EUR novamente.
COTACAO_CLEANUP_CRON=0 3 * * 0
COTACAO_CLEANUP_TIMEZONE=America/Sao_Paulo

# Simulação — taxas (IBPT + corretagem/logística)
# IBPT: consulta alíquotas por NCM da cultura. Sem token usa espelho público (valraw).
# Cadastro token oficial: https://deolhonoimposto.ibpt.org.br/
IBPT_ENABLED=true
IBPT_UF=MG
# IBPT_TOKEN=
# IBPT_CNPJ=00000000000000
# IBPT_API_URL=https://apidoni.ibpt.org.br/api/v1/produtos
# IBPT_VALRAW_BASE_URL=https://ibpt.valraw.com.br
# IBPT_VALRAW_TABELA=2026/26.1.H
# IBPT_UNIDADE_MEDIDA=SC
# IBPT_GTIN=SEM GTIN

# API customizada (opcional, substitui IBPT se preenchida)
# TAX_ESTIMATOR_API_URL=
# TAX_ESTIMATOR_API_KEY=
# TAX_ESTIMATOR_TIMEOUT_MS=6000