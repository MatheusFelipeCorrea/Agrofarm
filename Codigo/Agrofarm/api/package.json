{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:stable": "node src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:push": "prisma db push && prisma generate",
    "db:setup": "npm run db:up && npm run db:generate && npm run db:push && npm run db:seed",
    "db:pull": "prisma db pull",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node src/database/seeds/admin.seed.js",
    "db:verify": "node src/scripts/db-verify.js",
    "db:reset-demo": "node src/database/seeds/demo-reset.seed.js",
    "db:seed:mega": "node src/database/seeds/mega-demo.seed.js",
    "db:reseed:mega": "node src/database/seeds/mega-demo.seed.js -- --com-reset",
    "cotacao:cleanup": "node src/scripts/run-cotacao-cleanup.js",
    "evolution:status": "node scripts/evolution-cli.js status",
    "evolution:provisionar": "node scripts/evolution-cli.js provisionar",
    "evolution:conectar": "node scripts/evolution-cli.js conectar",
    "test:gemini-key": "node scripts/test-gemini-key.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "5.10.0",
    "@turf/turf": "^7.3.5",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.3",
    "prisma": "5.10.0",
    "vitest": "^2.1.9"
  }
}
