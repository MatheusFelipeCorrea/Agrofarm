{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/crons/cotacao-update",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/crons/cotacao-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/crons/arquivamento-mapa",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/crons/lembretes",
      "schedule": "0 7 * * *"
    }
  ]
}
